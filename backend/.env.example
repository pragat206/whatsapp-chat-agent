# === Application ===
APP_NAME=WhatsApp AI Agent
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-in-production
API_PREFIX=/api/v1
ALLOWED_HOSTS=["*"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/whatsapp_agent
DATABASE_ECHO=false

# === Redis ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# === JWT Auth ===
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === AiSensy ===
AISENSY_API_KEY=your-aisensy-api-key
AISENSY_API_BASE_URL=https://backend.aisensy.com
AISENSY_PROJECT_ID=your-project-id
AISENSY_WEBHOOK_SECRET=your-webhook-secret

# === LLM Provider ===
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# === Embeddings ===
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# === File Storage ===
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
S3_BUCKET_NAME=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=

# === Observability ===
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Business Config ===
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,hi
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=18:00
BUSINESS_TIMEZONE=Asia/Kolkata
MAX_UPLOAD_SIZE_MB=50
